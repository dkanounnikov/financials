  <step>
    <name>fact.account_fnb_business_checking_load_history</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>bicycle_finance local</connection>
    <sql>-- Query for monthly reporting
	
select 
	to_char(date_transaction, 'Month')|| ' ' || to_char(date_transaction, 'YYYY') as month_transaction
,	date_transaction
,	case when transaction_amount &lt; 0
		then 'Expenses'
		else 'Income'
	end as transaction_type
,	case 
		when date_part('day', date_transaction) between 22 and 27
			and 
			(	
				transaction_description like '%RENE%'
			or
				transaction_description like '%BERNICE%'
			or
				transaction_description like '%DANIEL%'
			or
				transaction_description like '%FRANSCOIS%'
			or
				transaction_description like '%IRINA%'
			or
				transaction_description like '%JEANRE%'
			or
				transaction_description like '%KSU%'
			or
				transaction_description like '%RHYN%'
			or
				transaction_description like '%LYNDEA%'
			or
				transaction_description like '%ROB%'
			or
				transaction_description like '% RUAN%'
			or
				transaction_description like '% SHAUN%'
			or
				transaction_description like '% ZANDRI%'
			)
			then 'Payroll'
		when date_part('day', date_transaction) between 1 and 3
			and 
			(	
				transaction_description like '%RENE%'
			or
				transaction_description like '%BERNICE%'
			or
				transaction_description like '%DANIEL%'
			or
				transaction_description like '%FRANSCOIS%'
			or
				transaction_description like '%IRINA%'
			or
				transaction_description like '%JEANRE%'
			or
				transaction_description like '%KSU%'
			or
				transaction_description like '%RHYN%'
			or
				transaction_description like '%LYNDEA%'
			or
				transaction_description like '%ROB%'
			or
				transaction_description like '%RUAN%'
			or
				transaction_description like '%SHAUN%'
			or
				transaction_description like '%ZANDRI%'
			)
			then 'Expense Claim'
		when transaction_description like '%MARXGORE%'
			then 'Accounting'
		when 
			(
				transaction_description like '%ACCOUNT FEE%'
			or
				transaction_description like '%SWIFT COMMISSION%'
			)
			then 'Bank Fees'
		when transaction_description like '%BICYCLE LLC%'
			then 'Customer Payment'
		when transaction_description like '%SARS%'
			then 'Tax Expenses'
		when transaction_description like '%MICROSTRATEGY%'
			then 'Software Maintenance Fee'
		when transaction_description like '%EVERNOTE%'
			then 'Software Maintenance Fee'
		when transaction_description like '%OMSUREPREM%'
			then 'Insurance'
		when transaction_description like '%DK EXPENSE%'
			and transaction_amount &lt; 0
			then 'Expense Claim'
		when transaction_description like '%DK%'
			and transaction_amount &lt; 0
			then 'Loan Repayment'
		when transaction_description like '%DK%'
			and transaction_amount > 0
			then 'Loan'
		when transaction_description like '%MICROSOFT%'
			and transaction_amount &lt; 0
			then 'Email Subscription'
		when transaction_description like '%OFFICE 365%'
			and transaction_amount &lt; 0
			then 'Email Subscription'
		else 'TBD'
	end as category
,	case 
		when 			(	
				transaction_description like '%RENE%'
			or
				transaction_description like '%BERNICE%'
			or
				transaction_description like '%DANIEL%'
			or
				transaction_description like '%FRANSCOIS%'
			or
				transaction_description like '%IRINA%'
			or
				transaction_description like '%JEANRE%'
			or
				transaction_description like '%KSU%'
			or
				transaction_description like '%RHYN%'
			or
				transaction_description like '%LYNDEA%'
			or
				transaction_description like '%ROB%'
			or
				transaction_description like '%RUAN%'
			or
				transaction_description like '%SHAUN%'
			or
				transaction_description like '%ZANDRI%'
			)
			then 'Employee'
		when transaction_description like '%MARXGORE%'
			then 'Marx Gore'
		when 
			(
				transaction_description like '%ACCOUNT FEE%'
			or
				transaction_description like '%SWIFT COMMISSION%'
			)
			then 'FNB'
		when transaction_description like '%BICYCLE LLC%'
			then 'Bicycle LLC'
		when transaction_description like '%SARS%'
			then 'SARS'
		when transaction_description like '%MICROSTRATEGY%'
			then 'MicroStrategy Inc'
		when transaction_description like '%OMSUREPREM%'
			then 'Old Mutual'
		when transaction_description like '%EVERNOTE%'
			then 'Evernote'
		when transaction_description like '%DK%'
			and transaction_amount &lt; 0
			then 'DK'
		when transaction_description like '%DK%'
			and transaction_amount > 0
			then 'DK'
		when transaction_description like '%MICROSOFT%'
			and transaction_amount &lt; 0
			then 'Microsoft'
		when transaction_description like '%OFFICE 365%'
			and transaction_amount &lt; 0
			then 'Microsoft'
		else 'TBD'
	end as payee
,	case 
		when transaction_description 
			like '%KSU%' and transaction_amount = -6435
		then ' RHYN SALARY'
		else transaction_description
	end as transaction_description
,	amount_deposited
,	amount_drawn
,	amount_balance
,	account_fnb_business_checking_history_id
from 
	fact.account_fnb_business_checking_load_history	
where 
--	date_transaction between '2023-11-25' and '2023-12-10'
	date_transaction > now()::date - 45 --'2024-02-15'
order by 
    date_transaction
,	account_fnb_business_checking_history_id
</sql>
