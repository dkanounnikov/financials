    <connection>bicycle_finance local</connection>
    <sql>-- New script in postgres.
-- Date: Apr 29, 2024
-- Time: 1:13:55 PM
-- Created by Dmitri
-- DBeaver Project Path: /Users/Dmitri/Library/DBeaverData/workspace6/General

-- Monthly Transactions from USA

select 
	to_char(date_transaction, 'Month')|| ' ' || to_char(date_transaction, 'YYYY') as month_transaction
,	date_transaction
,	case when transaction_amount &lt; 0
		then 'Expenses'
		else 'Income'
	end as transaction_type
,	case 
		-- Wells Fargo 
		when 
			(
				transaction_description like '%INTEREST PAYMENT%'
			or	
				transaction_description like '%WIRE TRANS SVC CHARGE%'
			or	
				transaction_description like '%DIRECT PAY%'
			or	
				transaction_description like '%RECURRING TRANSFER TO BICYCLE LLC BUSINESS MARKET RATE SAVINGS%'
			) and transaction_amount > 0
			then 'Bank Interest'
		when 
			(
				transaction_description like '%INTEREST PAYMENT%'
			or	
				transaction_description like '%WIRE TRANS SVC CHARGE%'
			or	
				transaction_description like '%DIRECT PAY%'
			or	
				transaction_description like '%RECURRING TRANSFER TO BICYCLE LLC BUSINESS MARKET RATE SAVINGS%'
			) and transaction_amount &lt; 0
			then 'Bank Charges'
		-- Cash Withdrawals 
		when 
			(
				transaction_description like '%ATM WITHDRAWAL%'
			or	
				transaction_description like '%ATM WITHDRAWAL%'
			)
			then 'Cash - Uncategorized'
		when transaction_description like '%MONTHLY OFFICE CLEANING%'
			then 'Office Expenses'
		-- WF Direct Pay
		when 
			(	
				transaction_description like '%WF Direct Pay%'
			and
				transaction_amount = -310
			)
			then 'Office Expenses'
		when 
			(	
				transaction_description like '%WF Direct Pay%'
			and
				transaction_amount = -1937.5
			)
			then 'Accounting Services'
		when 
			(	
				transaction_description like '%WF Direct Pay%'
			and
				transaction_amount = -310.9
			)
			then 'Accounting Services'
		when 
			(	
				transaction_description like '%WF Direct Pay%'
			and
				transaction_amount = -1937.5 - 2310
			)
			then 'Services'
		when 			(	
				transaction_description like '%WF Direct Pay%'
			and
				(
					transaction_amount = -240
				or
					transaction_amount = -200
				or
					transaction_amount = -160
				)
			)
			then 'Subcontracor'
		when 
			(	
				transaction_description like '%WF Direct Pay%'
			and
				transaction_amount = -2310
			)
			then 'Sales Services'
		-- EOF Direct Pay
		-- Genesys
		when transaction_description like '%AM COMMUNICATION%'
			then 'Revenue'
		when transaction_description like '%Genesys%'
			then 'Revenue'
		when transaction_description like '%TEAMWORK%'
			then 'Software and Subscriptions'
		when transaction_description like '%TD AUTO FINANCE%'
			then 'Vehicle Expenses'
		when transaction_description like '%4096%'
			then 'TBD'
		when transaction_description like '% IRS %'
			then 'Tax Expense'
		when transaction_description like '%AMZ STORE%'
			then 'TBD'
		when transaction_description like '%APPLE.COM%'
			then 'Software and Subscriptions'
		when transaction_description like '%IRONWOOD%'
			then 'Revenue'
		when transaction_description like '%Pronovos%'
			then 'Revenue'	
		when 
			(
				transaction_description like '%WAGE PAY%'
			or
				transaction_description like '%ADP Tax%'
			or
				transaction_description like '%ADP PAY%'
			)
			then 'Payroll'
		when transaction_description like '%VENMO PAYMENT 230225 1025485494505%'
			then 'Charity'
		when transaction_description like '%Office in Ballantyne%'
			then 'Office Expenses'
		when transaction_description like '%CITI CARD%'
			then 'TBD'
		when transaction_description like '%AMAZON%'
			then 'TBD'
		when transaction_description like '%Bicycle BI PTY LTD%'
			then 'Bicycle RSA'
		when transaction_description like '%IONOS%'
			then 'Infrastructure'
		when transaction_description like '%APPLECARD%'
			then 'TBD'
		when transaction_description like '%HISCOX%'
			then 'Insurance'
		when 			(	
				transaction_description like '%Wells Fargo Bank EDI PYMNTS%'
			and
				transaction_amount > 0
			)
			then 'Revenue'
		when transaction_description like '%Spectrum%'
			then 'Communications'
		when transaction_description like '%ATT Payment%'
			then 'Communications'
		when 
			(
				transaction_description like '%Tidal%'
			or
				transaction_description like '%INTERNATIONAL PURCHASE TRANSACTION FEE%'
			and
				transaction_amount = -0.19
			)
			then 'Software and Subscriptions'
		when 
			(
				lower(transaction_description) like lower('%SYNCHRONY BANK%')
			and
				(
					transaction_description like '%MOROZOVA%'
				or
					transaction_description like '%KANOUNN%'
				)
			)
			then 'Health Care'
		when transaction_description like '%Microsoft%'
			then 'Software and Subscriptions'
		when transaction_description like '%AMEDION%'
			then 'Travel'
		when transaction_description like '%NC SECRETARY OF FILING%'
			then 'Business Registration'
		when transaction_description like '%TESLA%'
			then 'Vehicle Expenses'
		when transaction_description like '%ZELLE TO VALLE BRENDA%'
			then 'Subcontractor'
		when transaction_description like '%ZELLE TO BRENDA%'
			then 'Subcontractor'
		when transaction_description like '%SWEET MANGO%'
			then 'Subcontractor'
		when transaction_description like '%MUSESCORE%'
			then 'Software and Subscriptions'
		when transaction_description like '%DK LOAN%'
			then 'Loans'
		when transaction_description like '%PARALLELS%'
			then 'Software and Subscriptions'
		when transaction_description like '%this_is_a_template%'
			then 'replace_with_the_correct_description'
		else 'TBD'
	end as category
-- Payees
,	case 
		-- Wells Fargo 
		when 
			(
				transaction_description like '%INTEREST PAYMENT%'
			or	
				transaction_description like '%WIRE TRANS SVC CHARGE%'
			or	
				transaction_description like '%DIRECT PAY%'
			or	
				transaction_description like '%RECURRING TRANSFER TO BICYCLE LLC BUSINESS MARKET RATE SAVINGS%'
			)
			then 'Wells Fargo'
		-- Cash Withdrawals 
		when 
			(
				transaction_description like '%ATM WITHDRAWAL%'
			or	
				transaction_description like '%ATM WITHDRAWAL%'
			)
			then 'Cash Withdrawal'
		when transaction_description like '%MONTHLY OFFICE CLEANING%'
			then 'Office Cleaning'
		-- WF Direct Pay
		when 
			(	
				transaction_description like '%WF Direct Pay%'
			and
				transaction_amount = -310
			)
			then 'Office Cleaning'
		when 
			(	
				transaction_description like '%WF Direct Pay%'
			and
				transaction_amount = -1937.5
			)
			then 'Bonka Consulting'
		when 
			(	
				transaction_description like '%WF Direct Pay%'
			and
				transaction_amount = -310.9
			)
			then 'Bonka Consulting'
		when 
			(	
				transaction_description like '%WF Direct Pay%'
			and
				transaction_amount = -1937.5 - 2310
			)
			then 'Bonka Consulting and Halo AI'
		when 			(	
				transaction_description like '%WF Direct Pay%'
			and
				(
					transaction_amount = -240
				or
					transaction_amount = -200
				or
					transaction_amount = -160
				)
			)
			then 'Natalia Ryzhikova'
		when 
			(	
				transaction_description like '%WF Direct Pay%'
			and
				transaction_amount = -2310
			)
			then 'Halo AI'
		-- EOF Direct Pay
		-- Genesys
		when transaction_description like '%AM COMMUNICATION%'
			then 'Genesys'
		when transaction_description like '%Genesys%'
			then 'Genesys'
		when transaction_description like '%TEAMWORK%'
			then 'Teamwork'
		when transaction_description like '%TD AUTO FINANCE%'
			then 'Tesla - TD'
		when transaction_description like '%4096%'
			then 'usbank'
		when transaction_description like '% IRS %'
			then 'IRS'
		when transaction_description like '%AMZ STORE%'
			then 'Amazon'
		when transaction_description like '%APPLE.COM%'
			then 'Apple'
		when transaction_description like '%IRONWOOD%'
			then 'Ironwood'
		when transaction_description like '%Pronovos%'
			then 'Pronovos'	
		when 
			(
				transaction_description like '%WAGE PAY%'
			or
				transaction_description like '%ADP Tax%'
			or
				transaction_description like '%ADP PAY%'
			)
			then 'ADP - Payroll'
		when transaction_description like '%VENMO PAYMENT 230225 1025485494505%'
			then 'Charity'
		when transaction_description like '%Office in Ballantyne%'
			then 'Office in Ballantyne'
		when transaction_description like '%CITI CARD%'
			then 'Citi'
		when transaction_description like '%AMAZON%'
			then 'Amazon'
		when transaction_description like '%Bicycle BI PTY LTD%'
			then 'Bicycle RSA'
		when transaction_description like '%IONOS%'
			then 'Ionos'
		when transaction_description like '%APPLECARD%'
			then 'Apple Card'
		when transaction_description like '%HISCOX%'
			then 'Hiscox Insurance'
		when 			(	
				transaction_description like '%Wells Fargo Bank EDI PYMNTS%'
			and
				transaction_amount > 0
			)
			then 'Octapharma'
		when transaction_description like '%Spectrum%'
			then 'Spectrum'
		when transaction_description like '%ATT Payment%'
			then 'AT&amp;T'
		when 
			(
				transaction_description like '%Tidal%'
			or
				transaction_description like '%INTERNATIONAL PURCHASE TRANSACTION FEE%'
			and
				transaction_amount = -0.19
			)
			then 'Tidal'
		when 
			(
				lower(transaction_description) like lower('%SYNCHRONY BANK%')
			and
				(
					transaction_description like '%MOROZOVA%'
				or
					transaction_description like '%KANOUNN%'
				)
			)
			then 'CareCredit'
		when transaction_description like '%Microsoft%'
			then 'Microsoft'
		when transaction_description like '%AMEDION%'
			then 'Amedion Group - Travel'
		when transaction_description like '%NC SECRETARY OF FILING%'
			then 'NC Secretary of Filing'
		when transaction_description like '%TESLA%'
			then 'Tesla'
		when transaction_description like '%ZELLE TO VALLE BRENDA%'
			then 'Brenda Valle'
		when transaction_description like '%ZELLE TO BRENDA%'
			then 'Brenda Valle'
		when transaction_description like '%MUSESCORE%'
			then 'MuseScore'
		when transaction_description like '%DK LOAN%'
			then 'DK'
		when transaction_description like '%PARALLELS%'
			then 'Parallels'
		when transaction_description like '%SWEET MANGO%'
			then 'Sweet Mango'
		when transaction_description like '%this_is_a_template%'
			then 'replace_with_the_correct_description'
		else 'TBD'
	end as payee
,	transaction_description
,	amount_deposited
,	amount_drawn
--,	transaction_amount
--,	check_number
from 
	fact.account_wf_business_checking_load_history
where
	date_transaction >= now()::date - 45 --'2024-01-01'
order by date_transaction
	
	</sql>
